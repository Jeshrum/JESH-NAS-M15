// =============================================================================
// JESH NAS M15 — Signal Indicator
// =============================================================================
// Same core logic that produced 16-year backtest results.
// Session: 9:30 AM – 11:30 AM New York time (2:30 PM – 4:30 PM WAT)
// =============================================================================

//@version=6
indicator("JESH NAS M15", overlay=true, max_lines_count=500, max_boxes_count=500, max_labels_count=500)

// ─── Input ────────────────────────────────────────────────────────────────────
account_size = input.int(10000, "Account Size ($)", minval=100, step=500, group="Settings")

// ─── Colors — Monochrome Dark Premium ────────────────────────────────────────
// Triangles: white for long, mid-grey for short — clear on dark charts
col_long_tri  = color.new(#F0F0F0, 0)
col_short_tri = color.new(#999999, 0)

// Position tool zones — very subtle, dark aesthetic
col_profit_long  = color.new(#CCCCCC, 88)   // barely-there light zone  (long)
col_profit_short = color.new(#888888, 88)   // barely-there grey zone   (short)
col_loss_zone    = color.new(#333333, 88)   // near-invisible dark zone (both)

// Position tool lines — monochrome hierarchy
col_entry  = color.new(#FFFFFF, 10)   // solid white — entry
col_sl     = color.new(#666666, 10)   // mid-grey    — SL
col_tp1    = color.new(#AAAAAA, 30)   // soft grey   — TP1 (dashed)
col_tp2    = color.new(#DDDDDD, 10)   // light grey  — TP2 (main target)
col_tp3    = color.new(#AAAAAA, 30)   // soft grey   — TP3 (dashed)

// Chart lines
col_pdh       = color.new(#AAAAAA, 45)
col_pdl       = color.new(#AAAAAA, 45)
col_fb_high   = color.new(#FFFFFF, 60)
col_fb_low    = color.new(#FFFFFF, 60)

// Label
col_label_bg  = color.new(#111111, 5)
col_label_txt = color.new(#E8E8E8, 0)

// ─── Session ──────────────────────────────────────────────────────────────────
NY         = "America/New_York"
in_session = not na(time("15", "0930-1130", NY))
is_first_bar = in_session and not in_session[1]
is_new_day   = dayofmonth != dayofmonth[1]

// ─── ATR ──────────────────────────────────────────────────────────────────────
atr = ta.atr(14)

// ─── Previous Day High / Low ──────────────────────────────────────────────────
[pdh_raw, pdl_raw] = request.security(syminfo.tickerid, "D", [high[1], low[1]], lookahead=barmerge.lookahead_off)
prev_day_high = pdh_raw
prev_day_low  = pdl_raw

// ─── PDH / PDL Lines ──────────────────────────────────────────────────────────
var line pdh_line = na
var line pdl_line = na

if is_new_day and not na(prev_day_high)
    line.delete(pdh_line)
    line.delete(pdl_line)
    pdh_line := line.new(bar_index, prev_day_high, bar_index + 1, prev_day_high,
         extend=extend.right, color=col_pdh, width=1, style=line.style_dashed)
    pdl_line := line.new(bar_index, prev_day_low, bar_index + 1, prev_day_low,
         extend=extend.right, color=col_pdl, width=1, style=line.style_dashed)

if barstate.islast and not na(prev_day_high)
    label.new(bar_index + 2, prev_day_high, "PDH",
         style=label.style_label_left, color=color.new(#111111, 100),
         textcolor=col_pdh, size=size.tiny)
    label.new(bar_index + 2, prev_day_low, "PDL",
         style=label.style_label_left, color=color.new(#111111, 100),
         textcolor=col_pdl, size=size.tiny)

// ─── First Bar ────────────────────────────────────────────────────────────────
var float fb_high = na
var float fb_low  = na

if is_new_day
    fb_high := na
    fb_low  := na

if is_first_bar
    fb_high := high
    fb_low  := low

var line fb_high_line = na
var line fb_low_line  = na

if is_first_bar
    line.delete(fb_high_line)
    line.delete(fb_low_line)
    fb_high_line := line.new(bar_index, fb_high, bar_index + 1, fb_high,
         extend=extend.right, color=col_fb_high, width=1, style=line.style_dotted)
    fb_low_line := line.new(bar_index, fb_low, bar_index + 1, fb_low,
         extend=extend.right, color=col_fb_low, width=1, style=line.style_dotted)

// ─── Sweep Detection ──────────────────────────────────────────────────────────
var bool pdh_swept = false
var bool pdl_swept = false

if is_new_day
    pdh_swept := false
    pdl_swept := false

if not na(prev_day_high) and not pdh_swept and high > prev_day_high
    pdh_swept := true
if not na(prev_day_low)  and not pdl_swept and low  < prev_day_low
    pdl_swept := true

pdh_confirmed = pdh_swept[1]
pdl_confirmed = pdl_swept[1]

plotshape(not pdh_swept[1] and pdh_swept, "PDH Swept", shape.circle, location.abovebar, color.new(#888888, 50), size=size.tiny)
plotshape(not pdl_swept[1] and pdl_swept, "PDL Swept", shape.circle, location.belowbar, color.new(#888888, 50), size=size.tiny)

// ─── One Trade Per Day ────────────────────────────────────────────────────────
var bool trade_taken = false
if is_new_day
    trade_taken := false

// ─── Entry Conditions ─────────────────────────────────────────────────────────
can_enter = (in_session and not trade_taken
            and not na(fb_high) and not na(fb_low)
            and not na(prev_day_high) and not na(prev_day_low)
            and not na(atr) and atr > 0)

long_signal  = (can_enter
               and ta.crossover(close, fb_high)
               and prev_day_high > fb_high
               and pdl_confirmed)

short_signal = (can_enter
               and ta.crossunder(close, fb_low)
               and prev_day_low < fb_low
               and pdh_confirmed)

if long_signal or short_signal
    trade_taken := true

// ─── Levels ───────────────────────────────────────────────────────────────────
float entry_l = long_signal  ? close   : na
float entry_s = short_signal ? close   : na
float sl_l    = long_signal  ? fb_low  : na
float sl_s    = short_signal ? fb_high : na

float r_l = long_signal  ? math.max(entry_l - sl_l, atr * 0.1) : na
float r_s = short_signal ? math.max(sl_s - entry_s, atr * 0.1) : na

float tp1_l = long_signal  ? entry_l + r_l       : na
float tp2_l = long_signal  ? entry_l + r_l * 2.0 : na
float tp3_l = long_signal  ? entry_l + r_l * 3.0 : na

float tp1_s = short_signal ? entry_s - r_s       : na
float tp2_s = short_signal ? entry_s - r_s * 2.0 : na
float tp3_s = short_signal ? entry_s - r_s * 3.0 : na

risk_amt = float(account_size) * 0.01
qty_l    = long_signal  ? math.max(1, math.round(risk_amt / r_l)) : na
qty_s    = short_signal ? math.max(1, math.round(risk_amt / r_s)) : na

// ─── Position Tool Visual ─────────────────────────────────────────────────────
// Mimics TradingView's built-in Long/Short Position tool.
// Zones extend 40 bars to the right. Labeled lines for Entry, SL, TP1, TP2, TP3.

box_right = bar_index + 40

if long_signal
    // ── Zones ──
    // Loss zone: SL → Entry
    box.new(bar_index, entry_l, box_right, sl_l,
         bgcolor=col_loss_zone, border_color=color.new(#555555, 70), border_width=1)
    // Profit zone: Entry → TP2
    box.new(bar_index, tp2_l, box_right, entry_l,
         bgcolor=col_profit_long, border_color=color.new(#CCCCCC, 60), border_width=1)

    // ── Lines ──
    line.new(bar_index, entry_l, box_right, entry_l, color=col_entry, width=1, style=line.style_solid)
    line.new(bar_index, sl_l,    box_right, sl_l,    color=col_sl,    width=1, style=line.style_solid)
    line.new(bar_index, tp1_l,   box_right, tp1_l,   color=col_tp1,   width=1, style=line.style_dashed)
    line.new(bar_index, tp2_l,   box_right, tp2_l,   color=col_tp2,   width=1, style=line.style_solid)
    line.new(bar_index, tp3_l,   box_right, tp3_l,   color=col_tp3,   width=1, style=line.style_dashed)

    // ── Price labels on lines ──
    label.new(box_right, entry_l, "ENTRY " + str.tostring(entry_l, "#.00"),
         style=label.style_label_left, color=color.new(#111111, 100),
         textcolor=col_entry, size=size.tiny)
    label.new(box_right, sl_l, "SL  " + str.tostring(sl_l, "#.00"),
         style=label.style_label_left, color=color.new(#111111, 100),
         textcolor=col_sl, size=size.tiny)
    label.new(box_right, tp2_l, "TP2  " + str.tostring(tp2_l, "#.00"),
         style=label.style_label_left, color=color.new(#111111, 100),
         textcolor=col_tp2, size=size.tiny)
    label.new(box_right, tp3_l, "TP3  " + str.tostring(tp3_l, "#.00"),
         style=label.style_label_left, color=color.new(#111111, 100),
         textcolor=col_tp3, size=size.tiny)

if short_signal
    // ── Zones ──
    // Loss zone: Entry → SL
    box.new(bar_index, sl_s, box_right, entry_s,
         bgcolor=col_loss_zone, border_color=color.new(#555555, 70), border_width=1)
    // Profit zone: TP2 → Entry
    box.new(bar_index, entry_s, box_right, tp2_s,
         bgcolor=col_profit_short, border_color=color.new(#AAAAAA, 60), border_width=1)

    // ── Lines ──
    line.new(bar_index, entry_s, box_right, entry_s, color=col_entry, width=1, style=line.style_solid)
    line.new(bar_index, sl_s,    box_right, sl_s,    color=col_sl,    width=1, style=line.style_solid)
    line.new(bar_index, tp1_s,   box_right, tp1_s,   color=col_tp1,   width=1, style=line.style_dashed)
    line.new(bar_index, tp2_s,   box_right, tp2_s,   color=col_tp2,   width=1, style=line.style_solid)
    line.new(bar_index, tp3_s,   box_right, tp3_s,   color=col_tp3,   width=1, style=line.style_dashed)

    // ── Price labels on lines ──
    label.new(box_right, entry_s, "ENTRY " + str.tostring(entry_s, "#.00"),
         style=label.style_label_left, color=color.new(#111111, 100),
         textcolor=col_entry, size=size.tiny)
    label.new(box_right, sl_s, "SL  " + str.tostring(sl_s, "#.00"),
         style=label.style_label_left, color=color.new(#111111, 100),
         textcolor=col_sl, size=size.tiny)
    label.new(box_right, tp2_s, "TP2  " + str.tostring(tp2_s, "#.00"),
         style=label.style_label_left, color=color.new(#111111, 100),
         textcolor=col_tp2, size=size.tiny)
    label.new(box_right, tp3_s, "TP3  " + str.tostring(tp3_s, "#.00"),
         style=label.style_label_left, color=color.new(#111111, 100),
         textcolor=col_tp3, size=size.tiny)

// ─── Signal Info Label ────────────────────────────────────────────────────────
if long_signal
    lbl = "▲ LONG MNQ\n" +
          "─────────────────\n" +
          "Entry  : " + str.tostring(entry_l, "#.00") + "\n" +
          "SL     : " + str.tostring(sl_l,    "#.00") + "  (−" + str.tostring(math.round(r_l, 1),       "#.0") + " pts)\n" +
          "TP 1R  : " + str.tostring(tp1_l,   "#.00") + "  (+" + str.tostring(math.round(r_l,       1), "#.0") + " pts)\n" +
          "TP 2R  : " + str.tostring(tp2_l,   "#.00") + "  (+" + str.tostring(math.round(r_l * 2.0, 1), "#.0") + " pts)\n" +
          "TP 3R  : " + str.tostring(tp3_l,   "#.00") + "  (+" + str.tostring(math.round(r_l * 3.0, 1), "#.0") + " pts)\n" +
          "Risk $" + str.tostring(math.round(risk_amt)) + "  |  Qty " + str.tostring(qty_l)
    label.new(bar_index, tp3_l + r_l * 0.3, lbl,
         style=label.style_label_down, color=col_label_bg, textcolor=col_label_txt, size=size.small)

if short_signal
    lbl = "▼ SHORT MNQ\n" +
          "─────────────────\n" +
          "Entry  : " + str.tostring(entry_s, "#.00") + "\n" +
          "SL     : " + str.tostring(sl_s,    "#.00") + "  (+" + str.tostring(math.round(r_s, 1),       "#.0") + " pts)\n" +
          "TP 1R  : " + str.tostring(tp1_s,   "#.00") + "  (−" + str.tostring(math.round(r_s,       1), "#.0") + " pts)\n" +
          "TP 2R  : " + str.tostring(tp2_s,   "#.00") + "  (−" + str.tostring(math.round(r_s * 2.0, 1), "#.0") + " pts)\n" +
          "TP 3R  : " + str.tostring(tp3_s,   "#.00") + "  (−" + str.tostring(math.round(r_s * 3.0, 1), "#.0") + " pts)\n" +
          "Risk $" + str.tostring(math.round(risk_amt)) + "  |  Qty " + str.tostring(qty_s)
    label.new(bar_index, tp3_s - r_s * 0.3, lbl,
         style=label.style_label_up, color=col_label_bg, textcolor=col_label_txt, size=size.small)

// ─── Triangle Signals (visible on dark charts) ────────────────────────────────
plotshape(long_signal,  "Long",  shape.triangleup,   location.belowbar, col_long_tri,  size=size.normal)
plotshape(short_signal, "Short", shape.triangledown, location.abovebar, col_short_tri, size=size.normal)

// ─── Session Background ───────────────────────────────────────────────────────
bgcolor(in_session ? color.new(#FFFFFF, 97) : na, title="NY Session")
