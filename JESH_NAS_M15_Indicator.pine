// =============================================================================
// JESH NAS M15 — Signal Indicator
// =============================================================================
// NAS100 Opening Range Breakout — NY Session Only
// Signal: 15m close breaks first-bar range with PDH/PDL sweep confirmation
// Session: 9:30–11:30 AM New York (2:30–4:30 PM WAT / Lagos)
// Backtest: $10k → $139k over 16 years (2010–2026) | 1,564 trades
// =============================================================================

//@version=6
indicator("JESH NAS M15", overlay=true, max_lines_count=500, max_boxes_count=500, max_labels_count=500)

// ─── Settings ─────────────────────────────────────────────────────────────────
var g = "Strategy Settings"
account_size = input.int(10000,  "Account Size ($)",          minval=100,  step=500,  group=g, tooltip="Your prop firm or personal account size. Risk is calculated at 1% per trade.")
_risk_info   = input.string("1% per trade — Prop Firm Safe", "Risk Mode", options=["1% per trade — Prop Firm Safe"], group=g, tooltip="Fixed 1% risk per signal. On $10k = $100 per trade. Never change this during evaluation phase.")
_session_inf = input.string("9:30–11:30 AM New York (2:30–4:30 PM Lagos)", "Active Session", options=["9:30–11:30 AM New York (2:30–4:30 PM Lagos)"], group=g, tooltip="Only take trades when the blue session background is visible.")
_filter_inf  = input.string("PDH/PDL Sweep Required (built-in)", "Entry Filter", options=["PDH/PDL Sweep Required (built-in)"], group=g, tooltip="ICT concept: price must sweep the previous day high (for shorts) or low (for longs) before a signal fires.")
_tp_info     = input.string("TP2 = 2R target | Force close 4:30 PM Lagos", "Take Profit", options=["TP2 = 2R target | Force close 4:30 PM Lagos"], group=g, tooltip="Set your TP at TP2R. The session ends at 4:30 PM Lagos — all positions must be closed by then.")

// ─── ICT Color Palette ────────────────────────────────────────────────────────
// Long = teal/aqua  |  Short = crimson/red  — standard ICT community palette

// Long colors
c_long_bright  = #26A69A        // teal — triangles, entry line
c_long_profit  = color.new(#26A69A, 85)  // teal fill — profit zone
c_long_border  = color.new(#26A69A, 40)  // teal border

// Short colors
c_short_bright = #EF5350        // crimson — triangles, entry line
c_short_profit = color.new(#EF5350, 85)  // crimson fill — profit zone
c_short_border = color.new(#EF5350, 40)  // crimson border

// Shared
c_sl_fill      = color.new(#FF1744, 90)  // very faint red — loss zone
c_sl_border    = color.new(#FF1744, 55)  // red border — loss zone
c_sl_line      = #FF1744                 // red — SL line
c_tp1_line     = color.new(#FFFFFF, 50)  // faint white — TP1 (minor)
c_tp3_line     = color.new(#FFFFFF, 50)  // faint white — TP3 (extension)
c_label_bg     = color.new(#0D0D0D, 8)   // near-black label bg
c_label_txt    = #E0E0E0                 // light grey text

// Chart levels
c_pdh          = color.new(#888888, 30)
c_pdl          = color.new(#888888, 30)
c_fb           = color.new(#CCCCCC, 55)

// Session background — subtle blue tint on NY session only
c_session      = color.new(#1565C0, 94)  // very dark navy, barely visible

// ─── Session ──────────────────────────────────────────────────────────────────
NY           = "America/New_York"
in_session   = not na(time("15", "0930-1130", NY))
is_first_bar = in_session and not in_session[1]
is_new_day   = dayofmonth != dayofmonth[1]

// ─── ATR ──────────────────────────────────────────────────────────────────────
atr = ta.atr(14)

// ─── Previous Day High / Low ──────────────────────────────────────────────────
[pdh_raw, pdl_raw] = request.security(syminfo.tickerid, "D", [high[1], low[1]], lookahead=barmerge.lookahead_off)
prev_day_high = pdh_raw
prev_day_low  = pdl_raw

// ─── PDH / PDL Lines ──────────────────────────────────────────────────────────
var line pdh_line = na
var line pdl_line = na

if is_new_day and not na(prev_day_high)
    line.delete(pdh_line)
    line.delete(pdl_line)
    pdh_line := line.new(bar_index, prev_day_high, bar_index + 1, prev_day_high,
         extend=extend.right, color=c_pdh, width=1, style=line.style_dashed)
    pdl_line := line.new(bar_index, prev_day_low, bar_index + 1, prev_day_low,
         extend=extend.right, color=c_pdl, width=1, style=line.style_dashed)

if barstate.islast and not na(prev_day_high)
    label.new(bar_index + 2, prev_day_high, "PDH",
         style=label.style_label_left, color=color.new(#0D0D0D, 100),
         textcolor=c_pdh, size=size.tiny)
    label.new(bar_index + 2, prev_day_low, "PDL",
         style=label.style_label_left, color=color.new(#0D0D0D, 100),
         textcolor=c_pdl, size=size.tiny)

// ─── First Bar ────────────────────────────────────────────────────────────────
var float fb_high = na
var float fb_low  = na

if is_new_day
    fb_high := na
    fb_low  := na

if is_first_bar
    fb_high := high
    fb_low  := low

var line fb_high_line = na
var line fb_low_line  = na

if is_first_bar
    line.delete(fb_high_line)
    line.delete(fb_low_line)
    fb_high_line := line.new(bar_index, fb_high, bar_index + 1, fb_high,
         extend=extend.right, color=c_fb, width=1, style=line.style_dotted)
    fb_low_line := line.new(bar_index, fb_low, bar_index + 1, fb_low,
         extend=extend.right, color=c_fb, width=1, style=line.style_dotted)

// ─── Sweep Detection ──────────────────────────────────────────────────────────
var bool pdh_swept = false
var bool pdl_swept = false

if is_new_day
    pdh_swept := false
    pdl_swept := false

if not na(prev_day_high) and not pdh_swept and high > prev_day_high
    pdh_swept := true
if not na(prev_day_low)  and not pdl_swept and low  < prev_day_low
    pdl_swept := true

pdh_confirmed = pdh_swept[1]
pdl_confirmed = pdl_swept[1]

plotshape(not pdh_swept[1] and pdh_swept, "PDH Swept", shape.circle, location.abovebar, color.new(#EF5350, 40), size=size.tiny)
plotshape(not pdl_swept[1] and pdl_swept, "PDL Swept", shape.circle, location.belowbar, color.new(#26A69A, 40), size=size.tiny)

// ─── One Trade Per Day ────────────────────────────────────────────────────────
var bool trade_taken = false
if is_new_day
    trade_taken := false

// ─── Entry Conditions ─────────────────────────────────────────────────────────
can_enter = (in_session and not trade_taken
            and not na(fb_high) and not na(fb_low)
            and not na(prev_day_high) and not na(prev_day_low)
            and not na(atr) and atr > 0)

long_signal  = (can_enter
               and ta.crossover(close, fb_high)
               and prev_day_high > fb_high
               and pdl_confirmed)

short_signal = (can_enter
               and ta.crossunder(close, fb_low)
               and prev_day_low < fb_low
               and pdh_confirmed)

if long_signal or short_signal
    trade_taken := true

// ─── Levels ───────────────────────────────────────────────────────────────────
float entry_l = long_signal  ? close   : na
float entry_s = short_signal ? close   : na
float sl_l    = long_signal  ? fb_low  : na
float sl_s    = short_signal ? fb_high : na

float r_l = long_signal  ? math.max(entry_l - sl_l, atr * 0.1) : na
float r_s = short_signal ? math.max(sl_s - entry_s, atr * 0.1) : na

float tp1_l = long_signal  ? entry_l + r_l       : na
float tp2_l = long_signal  ? entry_l + r_l * 2.0 : na
float tp3_l = long_signal  ? entry_l + r_l * 3.0 : na

float tp1_s = short_signal ? entry_s - r_s       : na
float tp2_s = short_signal ? entry_s - r_s * 2.0 : na
float tp3_s = short_signal ? entry_s - r_s * 3.0 : na

risk_amt = float(account_size) * 0.01
qty_l    = long_signal  ? math.max(1, math.round(risk_amt / r_l)) : na
qty_s    = short_signal ? math.max(1, math.round(risk_amt / r_s)) : na

// ─── Position Tool Visual ─────────────────────────────────────────────────────
// Compact: box extends only 20 bars (clean, not sprawling)
bx = bar_index + 20

if long_signal
    // Zones
    box.new(bar_index, tp2_l, bx, entry_l,
         bgcolor=c_long_profit, border_color=c_long_border, border_width=1)
    box.new(bar_index, entry_l, bx, sl_l,
         bgcolor=c_sl_fill, border_color=c_sl_border, border_width=1)
    // Lines
    line.new(bar_index, entry_l, bx, entry_l, color=color.new(#26A69A, 0),  width=2, style=line.style_solid)
    line.new(bar_index, sl_l,    bx, sl_l,    color=color.new(#FF1744, 0),  width=1, style=line.style_solid)
    line.new(bar_index, tp1_l,   bx, tp1_l,   color=color.new(#26A69A, 60), width=1, style=line.style_dashed)
    line.new(bar_index, tp2_l,   bx, tp2_l,   color=color.new(#26A69A, 0),  width=1, style=line.style_solid)
    line.new(bar_index, tp3_l,   bx, tp3_l,   color=color.new(#26A69A, 60), width=1, style=line.style_dashed)
    // Right-edge price labels
    label.new(bx, entry_l, " E  " + str.tostring(entry_l, "#.00"),
         style=label.style_label_right, color=color.new(#0D0D0D, 100),
         textcolor=color.new(#26A69A, 0), size=size.tiny)
    label.new(bx, sl_l,    " SL " + str.tostring(sl_l, "#.00"),
         style=label.style_label_right, color=color.new(#0D0D0D, 100),
         textcolor=color.new(#FF1744, 0), size=size.tiny)
    label.new(bx, tp2_l,   " T2 " + str.tostring(tp2_l, "#.00"),
         style=label.style_label_right, color=color.new(#0D0D0D, 100),
         textcolor=color.new(#26A69A, 0), size=size.tiny)
    label.new(bx, tp3_l,   " T3 " + str.tostring(tp3_l, "#.00"),
         style=label.style_label_right, color=color.new(#0D0D0D, 100),
         textcolor=color.new(#26A69A, 30), size=size.tiny)

if short_signal
    // Zones
    box.new(bar_index, entry_s, bx, tp2_s,
         bgcolor=c_short_profit, border_color=c_short_border, border_width=1)
    box.new(bar_index, sl_s,    bx, entry_s,
         bgcolor=c_sl_fill, border_color=c_sl_border, border_width=1)
    // Lines
    line.new(bar_index, entry_s, bx, entry_s, color=color.new(#EF5350, 0),  width=2, style=line.style_solid)
    line.new(bar_index, sl_s,    bx, sl_s,    color=color.new(#FF1744, 0),  width=1, style=line.style_solid)
    line.new(bar_index, tp1_s,   bx, tp1_s,   color=color.new(#EF5350, 60), width=1, style=line.style_dashed)
    line.new(bar_index, tp2_s,   bx, tp2_s,   color=color.new(#EF5350, 0),  width=1, style=line.style_solid)
    line.new(bar_index, tp3_s,   bx, tp3_s,   color=color.new(#EF5350, 60), width=1, style=line.style_dashed)
    // Right-edge price labels
    label.new(bx, entry_s, " E  " + str.tostring(entry_s, "#.00"),
         style=label.style_label_right, color=color.new(#0D0D0D, 100),
         textcolor=color.new(#EF5350, 0), size=size.tiny)
    label.new(bx, sl_s,    " SL " + str.tostring(sl_s, "#.00"),
         style=label.style_label_right, color=color.new(#0D0D0D, 100),
         textcolor=color.new(#FF1744, 0), size=size.tiny)
    label.new(bx, tp2_s,   " T2 " + str.tostring(tp2_s, "#.00"),
         style=label.style_label_right, color=color.new(#0D0D0D, 100),
         textcolor=color.new(#EF5350, 0), size=size.tiny)
    label.new(bx, tp3_s,   " T3 " + str.tostring(tp3_s, "#.00"),
         style=label.style_label_right, color=color.new(#0D0D0D, 100),
         textcolor=color.new(#EF5350, 30), size=size.tiny)

// ─── Signal Info Label ────────────────────────────────────────────────────────
if long_signal
    lbl = ("▲ LONG MNQ\n"
         + "─────────────────\n"
         + "Entry  : " + str.tostring(entry_l, "#.00") + "\n"
         + "SL     : " + str.tostring(sl_l,    "#.00") + "  (−" + str.tostring(math.round(r_l,       1), "#.0") + " pts)\n"
         + "TP 1R  : " + str.tostring(tp1_l,   "#.00") + "  (+" + str.tostring(math.round(r_l,       1), "#.0") + " pts)\n"
         + "TP 2R  : " + str.tostring(tp2_l,   "#.00") + "  (+" + str.tostring(math.round(r_l * 2.0, 1), "#.0") + " pts)\n"
         + "TP 3R  : " + str.tostring(tp3_l,   "#.00") + "  (+" + str.tostring(math.round(r_l * 3.0, 1), "#.0") + " pts)\n"
         + "Risk $" + str.tostring(math.round(risk_amt)) + "  |  Qty " + str.tostring(qty_l))
    label.new(bar_index, tp3_l + r_l * 0.4, lbl,
         style=label.style_label_down,
         color=c_label_bg, textcolor=color.new(#26A69A, 0), size=size.small)

if short_signal
    lbl = ("▼ SHORT MNQ\n"
         + "─────────────────\n"
         + "Entry  : " + str.tostring(entry_s, "#.00") + "\n"
         + "SL     : " + str.tostring(sl_s,    "#.00") + "  (+" + str.tostring(math.round(r_s,       1), "#.0") + " pts)\n"
         + "TP 1R  : " + str.tostring(tp1_s,   "#.00") + "  (−" + str.tostring(math.round(r_s,       1), "#.0") + " pts)\n"
         + "TP 2R  : " + str.tostring(tp2_s,   "#.00") + "  (−" + str.tostring(math.round(r_s * 2.0, 1), "#.0") + " pts)\n"
         + "TP 3R  : " + str.tostring(tp3_s,   "#.00") + "  (−" + str.tostring(math.round(r_s * 3.0, 1), "#.0") + " pts)\n"
         + "Risk $" + str.tostring(math.round(risk_amt)) + "  |  Qty " + str.tostring(qty_s))
    label.new(bar_index, tp3_s - r_s * 0.4, lbl,
         style=label.style_label_up,
         color=c_label_bg, textcolor=color.new(#EF5350, 0), size=size.small)

// ─── Triangles ────────────────────────────────────────────────────────────────
plotshape(long_signal,  "Long",  shape.triangleup,   location.belowbar, color.new(#26A69A, 0), size=size.normal)
plotshape(short_signal, "Short", shape.triangledown, location.abovebar, color.new(#EF5350, 0), size=size.normal)

// ─── Session Highlight ────────────────────────────────────────────────────────
// Blue tint on NY session only — rest of chart stays normal
bgcolor(in_session ? c_session : na, title="NY Session (2:30–4:30 PM Lagos)")
