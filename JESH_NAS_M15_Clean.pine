// =============================================================================
// JESH NAS M15 — Clean Strategy (Based on JDUB)
// =============================================================================
// NAS100 Opening Range Breakout — NY Session
// Entry: Close crosses First Bar High/Low
// TP:    Previous Day High / Low
// SL:    Opposite end of First Bar
// Keys:  Force Close EOD ✓ | Cancel Orders ✓ | One TP Per Direction ✓
// Sweeps: OFF (pure breakout logic — highest win rate)
// =============================================================================

//@version=6
strategy("JESH NAS M15 — Clean",
     overlay=true,
     initial_capital=10000,
     default_qty_type=strategy.fixed,
     default_qty_value=1,
     margin_long=0.01,
     margin_short=0.01,
     commission_type=strategy.commission.cash_per_contract,
     commission_value=0.5,
     pyramiding=1,
     max_lines_count=200,
     max_boxes_count=100)

// ═══════════════════════════════════════════════════════════════════════════════
//  INPUTS
// ═══════════════════════════════════════════════════════════════════════════════

var g_session = "Session"
session_input        = input.session("0930-1600", "Trading Session NY",  group=g_session)
enable_force_close   = input.bool(true,  "Force Close Before EOD",        group=g_session, tooltip="Close all positions in last 2 bars before 17:00 NY")
enable_cancel_orders = input.bool(true,  "Cancel Orders at Session End",   group=g_session)
use_limit_orders     = input.bool(false, "Use Limit Orders (vs Market)",   group=g_session, tooltip="Limit = enter at FB level. Market = enter at crossover bar close. Market tested higher win rate.")
one_tp_per_dir       = input.bool(true,  "One TP Per Direction Per Day",   group=g_session)

var g_risk = "Risk"
account_size   = input.int(10000,  "Account Size ($)",  step=500,  group=g_risk)
risk_mode      = input.string("Normal (2%)", "Risk Mode",
     options=["Conservative (1%)", "Normal (2%)", "Aggressive (3%)"], group=g_risk)

var g_vis = "Visuals"
show_levels    = input.bool(true, "Show PDH/PDL + First Bar Levels", group=g_vis)
pdh_col        = input.color(color.red,    "PDH Color", group=g_vis)
pdl_col        = input.color(color.green,  "PDL Color", group=g_vis)
fb_h_col       = input.color(color.orange, "FB High Color", group=g_vis)
fb_l_col       = input.color(color.blue,   "FB Low Color",  group=g_vis)

// ═══════════════════════════════════════════════════════════════════════════════
//  RISK CALCULATION
// ═══════════════════════════════════════════════════════════════════════════════

risk_pct    = risk_mode == "Conservative (1%)" ? 0.01 :
              risk_mode == "Normal (2%)"        ? 0.02 : 0.03
risk_amount = math.round(account_size * risk_pct)

// ═══════════════════════════════════════════════════════════════════════════════
//  SESSION DETECTION
// ═══════════════════════════════════════════════════════════════════════════════

ny = "America/New_York"
is_in_session      = not na(time(timeframe.period, session_input, ny))
first_bar_session  = is_in_session and not is_in_session[1]
session_ended      = is_in_session[1] and not is_in_session

// Force close window: last 2 bars before 17:00
tf_secs       = timeframe.in_seconds()
close_start_m = (17 * 60) - (2 * tf_secs / 60)
fc_hour       = math.floor(close_start_m / 60)
fc_min        = close_start_m % 60
fc_session    = str.format("{0,number,00}{1,number,00}-1700", fc_hour, fc_min)
in_force_close = enable_force_close and not na(time(timeframe.period, fc_session, ny))

can_enter_trade = is_in_session and not in_force_close

// ═══════════════════════════════════════════════════════════════════════════════
//  PREVIOUS DAY HIGH / LOW
// ═══════════════════════════════════════════════════════════════════════════════

newDay = (dayofweek != dayofweek[1] or dayofmonth != dayofmonth[1]) and dayofweek != dayofweek.sunday

var float curr_day_high = na
var float curr_day_low  = na
var float prev_day_high = na
var float prev_day_low  = na

if newDay
    prev_day_high := curr_day_high
    prev_day_low  := curr_day_low
    curr_day_high := high
    curr_day_low  := low
else
    curr_day_high := math.max(nz(curr_day_high, high), high)
    curr_day_low  := math.min(nz(curr_day_low,  low),  low)

// PDH / PDL Lines
var line pdh_line = na
var line pdl_line = na
if newDay and not na(prev_day_high) and show_levels
    line.delete(pdh_line)
    line.delete(pdl_line)
    pdh_line := line.new(bar_index, prev_day_high, bar_index+1, prev_day_high,
         extend=extend.right, color=color.new(pdh_col, 20), width=2, style=line.style_dashed)
    pdl_line := line.new(bar_index, prev_day_low, bar_index+1, prev_day_low,
         extend=extend.right, color=color.new(pdl_col, 20), width=2, style=line.style_dashed)

// ═══════════════════════════════════════════════════════════════════════════════
//  FIRST BAR HIGH / LOW
// ═══════════════════════════════════════════════════════════════════════════════

var float first_bar_high = na
var float first_bar_low  = na

if first_bar_session
    first_bar_high := high
    first_bar_low  := low

plot(show_levels and not na(first_bar_high) and is_in_session ? first_bar_high : na,
     "FB High", color=fb_h_col, linewidth=2, style=plot.style_steplinebr)
plot(show_levels and not na(first_bar_low) and is_in_session ? first_bar_low : na,
     "FB Low",  color=fb_l_col, linewidth=2, style=plot.style_steplinebr)

// ═══════════════════════════════════════════════════════════════════════════════
//  DAILY TRADE TRACKING
// ═══════════════════════════════════════════════════════════════════════════════

var bool long_taken_today  = false
var bool short_taken_today = false
var bool long_tp_hit       = false
var bool short_tp_hit      = false

if first_bar_session
    long_taken_today  := false
    short_taken_today := false
    long_tp_hit       := false
    short_tp_hit      := false

// Track TP hits
if strategy.closedtrades != strategy.closedtrades[1]
    last_profit = strategy.closedtrades.profit(strategy.closedtrades - 1)
    last_id     = strategy.closedtrades.entry_id(strategy.closedtrades - 1)
    if last_profit > 0
        if str.contains(last_id, "Long")
            long_tp_hit := true
        else if str.contains(last_id, "Short")
            short_tp_hit := true

// ═══════════════════════════════════════════════════════════════════════════════
//  ENTRY CONDITIONS
// ═══════════════════════════════════════════════════════════════════════════════

long_condition = (
     can_enter_trade and
     not long_taken_today and
     not na(first_bar_high) and not na(prev_day_high) and
     ta.crossover(close, first_bar_high) and
     prev_day_high > first_bar_high and
     (not one_tp_per_dir or not long_tp_hit))

short_condition = (
     can_enter_trade and
     not short_taken_today and
     not na(first_bar_low) and not na(prev_day_low) and
     ta.crossunder(close, first_bar_low) and
     prev_day_low < first_bar_low and
     (not one_tp_per_dir or not short_tp_hit))

// ═══════════════════════════════════════════════════════════════════════════════
//  POSITION SIZING
// ═══════════════════════════════════════════════════════════════════════════════

calc_qty(entry, sl) =>
    dist = math.abs(entry - sl)
    dist > 0 ? math.max(1, math.round(risk_amount / dist)) : 1

// ═══════════════════════════════════════════════════════════════════════════════
//  STRATEGY EXECUTION
// ═══════════════════════════════════════════════════════════════════════════════

if long_condition and strategy.position_size == 0
    entry_price = use_limit_orders ? first_bar_high : close
    sl_price    = first_bar_low
    tp_price    = prev_day_high
    qty         = calc_qty(entry_price, sl_price)

    if use_limit_orders
        strategy.entry("Long", strategy.long,  qty=qty, limit=entry_price)
    else
        strategy.entry("Long", strategy.long,  qty=qty)
    strategy.exit("Long Exit", "Long", limit=tp_price, stop=sl_price)
    long_taken_today := true

if short_condition and strategy.position_size == 0
    entry_price = use_limit_orders ? first_bar_low : close
    sl_price    = first_bar_high
    tp_price    = prev_day_low
    qty         = calc_qty(entry_price, sl_price)

    if use_limit_orders
        strategy.entry("Short", strategy.short, qty=qty, limit=entry_price)
    else
        strategy.entry("Short", strategy.short, qty=qty)
    strategy.exit("Short Exit", "Short", limit=tp_price, stop=sl_price)
    short_taken_today := true

// Force close
if in_force_close and strategy.position_size != 0
    strategy.close_all(comment="Force Close EOD")

// Cancel orders at session end
if enable_cancel_orders and session_ended
    strategy.cancel_all()

// ═══════════════════════════════════════════════════════════════════════════════
//  VISUALS
// ═══════════════════════════════════════════════════════════════════════════════

bgcolor(is_in_session    ? color.new(color.blue, 95) : na, title="Session")
bgcolor(in_force_close   ? color.new(color.red,  90) : na, title="Force Close Window")

plotshape(long_condition,  "Long",  shape.triangleup,   location.belowbar, color.green, size=size.small)
plotshape(short_condition, "Short", shape.triangledown, location.abovebar, color.red,   size=size.small)
